# List & Create Discounts
class DiscountListCreateView(generics.ListCreateAPIView):
    queryset = DbDiscount.objects.all()
    serializer_class = DiscountSerializer
    permission_classes = [IsAuthenticated]

    def get_queryset(self):
        contract_id = self.kwargs.get('contract_id')
        discounts = DbDiscount.objects.filter(contract_id=contract_id)
        if not discounts.exists():
            raise NotFound(detail="No discount yet", code=HTTP_404_NOT_FOUND)
        return discounts

    def create(self, request, *args, **kwargs):
        try:
            return super().create(request, *args, **kwargs)
        except Exception as e:
            return Response({'detail': "Already exists"}, status=HTTP_409_CONFLICT)

# Retrieve & Update a Discount
class DiscountRetrieveUpdateView(generics.RetrieveUpdateAPIView):
    queryset = DbDiscount.objects.all()
    serializer_class = DiscountSerializer
    permission_classes = [IsAuthenticated]

    def get_object(self):
        discount_id = self.kwargs.get('pk')
        discount = get_object_or_404(DbDiscount, id=discount_id)
        return discount

