# Create Owner
class CreateOwnerView(generics.CreateAPIView):
    queryset = Owner.objects.all()
    serializer_class = OwnerSerializer
    permission_classes = [IsAuthenticated]

    def perform_create(self, serializer):
        if Owner.objects.filter(email=self.request.data.get('email')).exists():
            return Response({'detail': 'Already exists'}, status=status.HTTP_409_CONFLICT)
        serializer.save()


# Retrieve Single Owner
class RetrieveOwnerView(generics.RetrieveAPIView):
    queryset = Owner.objects.all()
    serializer_class = OwnerSerializer
    permission_classes = [IsAuthenticated]
    lookup_field = 'id'


# List All Owners with Sorting
class ListOwnersView(generics.ListAPIView):
    serializer_class = OwnerSerializer
    permission_classes = [IsAuthenticated]

    def get_queryset(self):
        sort = self.request.query_params.get('sort', 'id')
        what = self.request.query_params.get('what', '1')
        order = "" if what == "1" else "-"
        queryset = Owner.objects.all().order_by(f"{order}{sort}")
        if not queryset.exists():
            return Response({'detail': 'No owner yet.'}, status=status.HTTP_404_NOT_FOUND)
        return queryset


# Update Owner
class UpdateOwnerView(generics.UpdateAPIView):
    queryset = Owner.objects.all()
    serializer_class = OwnerSerializer
    permission_classes = [IsAuthenticated]
    lookup_field = 'id'


# Search Owner by Name
class SearchOwnerView(generics.ListAPIView):
    serializer_class = OwnerSerializer
    permission_classes = [IsAuthenticated]

    def get_queryset(self):
        name = self.request.query_params.get('name', '')
        queryset = Owner.objects.filter(
            Q(name__icontains=name)
        )
        if not queryset.exists():
            return Response({'detail': 'Owner not found.'}, status=status.HTTP_404_NOT_FOUND)
        return queryset


# Delete Owner
class DeleteOwnerView(generics.DestroyAPIView):
    queryset = Owner.objects.all()
    permission_classes = [IsAuthenticated]
    lookup_field = 'id'

    def destroy(self, request, *args, **kwargs):
        instance = self.get_object()
        if instance.buildings.exists():
            return Response({'detail': 'Owner cannot be deleted because it has associated buildings'},
                            status=status.HTTP_400_BAD_REQUEST)
        self.perform_destroy(instance)
        return Response({'message': 'Owner deleted successfully'}, status=status.HTTP_204_NO_CONTENT)

# END OF OWNER VIEW ###################################


