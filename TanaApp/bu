# START OF ELEVATOR VIEW ############################
class ElevatorCreateView(generics.CreateAPIView):
    queryset = DbElevator.objects.all()
    serializer_class = ElevatorCreateSerializer
    permission_classes = [IsAuthenticated]

    def create(self, request, *args, **kwargs):
        serializer = self.get_serializer(data=request.data)
        serializer.is_valid(raise_exception=True)
        elevator = serializer.save()

        # Creating warranty
        warranty_duration = int(request.data.get("id", 0))
        DbWarranty.objects.create(
            start_date=request.data.get("start_date"),
            end_date=datetime.strptime(request.data.get("start_date"), '%Y-%m-%d').date() + relativedelta(
                months=warranty_duration),
            elevator=elevator
        )

        return Response(serializer.data, status=status.HTTP_201_CREATED)


class ElevatorListView(generics.ListAPIView):
    queryset = DbElevator.objects.all()
    serializer_class = ElevatorSerializer
    permission_classes = [IsAuthenticated]


class ElevatorDetailView(generics.RetrieveAPIView):
    queryset = DbElevator.objects.all()
    serializer_class = ElevatorSerializer
