# START OF Partial Payment #############################
class PartialPaymentListCreateView(generics.ListCreateAPIView):
    queryset = PartialPayment.objects.all()
    serializer_class = PartialPaymentSerializer
    permission_classes = [IsAuthenticated]

    def create(self, request, *args, **kwargs):
        try:
            with transaction.atomic():
                serializer = self.get_serializer(data=request.data)
                serializer.is_valid(raise_exception=True)
                serializer.save()
                return Response(serializer.data, status=status.HTTP_201_CREATED)
        except Exception as e:
            raise ValidationError({"detail": str(e)})


class PartialPaymentRetrieveUpdateView(generics.RetrieveUpdateAPIView):
    queryset = PartialPayment.objects.all()
    serializer_class = PartialPaymentSerializer
    permission_classes = [IsAdminOrReadOnly]
    lookup_field = "id"

    def update(self, request, *args, **kwargs):
        instance = self.get_object()
        amt = request.data.get("amount", 0)
        total = request.data.get("total", instance.total)

        if amt + instance.amount > instance.total:
            raise ValidationError("Payment cannot exceed total amount.")

        with transaction.atomic():
            instance.amount += amt
            instance.total = total
            instance.save()

            contract = get_object_or_404(Contract, id=instance.contract.id)
            if contract.payed != "two":
                contract.payed = "two"
                contract.save()

        return Response(PartialPaymentSerializer(instance).data, status=status.HTTP_200_OK)


# END OF Partial Payment #############################


