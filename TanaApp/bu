    lookup_field = "id"


class ElevatorUpdateView(generics.UpdateAPIView):
    queryset = DbElevator.objects.all()
    serializer_class = ElevatorCreateSerializer
    permission_classes = [IsAuthenticated]
    lookup_field = "id"

    def update(self, request, *args, **kwargs):
        elevator = get_object_or_404(DbElevator, id=kwargs.get("id"))
        serializer = self.get_serializer(elevator, data=request.data, partial=True)
        serializer.is_valid(raise_exception=True)
        self.perform_update(serializer)

        # Updating warranty
        warranty = get_object_or_404(DbWarranty, elevator=elevator)
        warranty.end_date = datetime.strptime(request.data.get("start_date"), '%Y-%m-%d').date() + relativedelta(
            months=int(request.data.get("id", 0)))
        warranty.save()

        return Response(serializer.data, status=status.HTTP_200_OK)


